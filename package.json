{
  "name": "react-nt-modal",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode=demo",
    "build": "npm run build:code",
    "build:code": "tsc -b && vite build --mode=lib",
    "build:demo": "tsc -b && vite build --mode=demo",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "main": "./dist/nt-modal.umd.js",
  "module": "./dist/nt-modal.es.js",
  "exports": {
    ".": {
      "import": "./dist/nt-modal.es.js",
      "require": "./dist/nt-modal.umd.js"
    },
    "./nt-modal.css": "./dist/nt-modal.css"
  },
  "files": ["dist", "src"],
  "bugs": {
    "url": "https://github.com/noistommy/react-nt-modal/issues"
  },
  "homepage": "https://github.com/noistommy/react-nt-modal#readme",
  "keywords": ["react", "modal", "portal", "provider"],
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/noistommy/react-nt-modal.git"
  }
}
